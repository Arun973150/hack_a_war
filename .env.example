# ─── Google Vertex AI ────────────────────────────────────────────────────────
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Vertex AI Models ────────────────────────────────────────────────────────
GEMINI_FLASH_LITE_MODEL=gemini-2.0-flash-lite
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=regulatory_docs

# ─── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ─── Supabase (PostgreSQL + Storage) ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET_REGULATORY_DOCS=regulatory-docs
SUPABASE_BUCKET_PROCESSED=processed-docs
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# ─── LangSmith ───────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=red-forge-compliance

# ─── Prefect ─────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ─── FastAPI ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-in-production
API_DEBUG=true
API_KEY=your-api-key

# ─── AWS / Production ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=

# ─── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=redforge
KEYCLOAK_CLIENT_ID=redforge-api

# ─── External Integrations ───────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_EMAIL=your-email@example.com
JIRA_PROJECT_KEY=COMP

# ─── Slack ───────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Gmail SMTP ──────────────────────────────────────────────────────────────
SMTP_SENDER_EMAIL=
SMTP_APP_PASSWORD=

# ─── Regulatory Sources ──────────────────────────────────────────────────────
EUR_LEX_BASE_URL=https://eur-lex.europa.eu
SEBI_BASE_URL=https://www.sebi.gov.in
RBI_BASE_URL=https://www.rbi.org.in

# ─── Background Scanners ────────────────────────────────────────────────────
SCAN_INTERVAL_HOURS=6
HORIZON_SCAN_INTERVAL_HOURS=12
